# Contoh konfigurasi n8n MCP Server. Salin menjadi .env dan isi nilainya.

# ── n8n API ───────────────────────────────────────────────────────────────────
# URL dasar n8n REST API. Contoh: http://localhost:5678/api/v1
N8N_API_BASE_URL=http://localhost:5678/api/v1
# API key n8n (Settings → n8n API → Create an API key)
N8N_API_KEY=
# Timeout HTTP ke n8n dalam detik (default: 30)
N8N_TIMEOUT=30

# ── Server ────────────────────────────────────────────────────────────────────
MCP_SERVER_NAME=n8n-mcp
MCP_LOG_LEVEL=INFO

# Transport saat `python -m n8n_mcp` (stdio | http | sse).
# Untuk Docker/cloud, uvicorn memakai n8n_mcp.asgi:app (lihat Dockerfile).
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# ── OAuth via Authentik (WAJIB untuk Claude Web / claude.ai) ──────────────────
# URL publik MCP server ini (untuk redirect OAuth). Contoh: https://n8n-mcp.example.com
MCP_BASE_URL=

# URL dasar Authentik. Contoh: https://auth.example.com
AUTHENTIK_BASE_URL=
# Slug OAuth2/OIDC Provider di Authentik. Contoh: n8n-mcp
AUTHENTIK_APP_SLUG=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
# preferred_username yang diizinkan, dipisah koma. Kosong = semua user diizinkan.
AUTHENTIK_ALLOWED_USERNAMES=

# ── API Key (klien non-OAuth: VS Code / CLI) ──────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Kosongkan untuk menonaktifkan (lokal/stdio).
MCP_API_KEY=
